# Netlify Database provides this automatically once you run `netlify db init`
# or link a database from the Netlify dashboard — you generally won't set this
# by hand in production. For any other Postgres host, paste its connection string here.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional. Pre-fills the email field on the one-time admin setup screen —
# doesn't create the account or set a password, just saves typing it once.
# You still choose your own password directly on that screen.
ADMIN_EMAIL=abhikacharya90@gmail.com
