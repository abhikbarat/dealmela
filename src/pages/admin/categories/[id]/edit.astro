---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import Icon from '../../../../components/Icon.astro';
import {
  getCategoryTree,
  getCategoryByIdForAdmin,
  updateCategory,
  isCategorySlugTaken,
  getCategoryDeleteBlockers,
  deleteCategory,
} from '../../../../lib/queries.js';

const id = Number(Astro.params.id);
const existing = await getCategoryByIdForAdmin(id);
if (!existing) return Astro.rewrite('/404');

const tree = await getCategoryTree();
const topLevel = tree.filter((c) => c.id !== id).map((c) => ({ id: c.id, name: c.name }));
const ICONS = ['cpu', 'smartphone', 'laptop', 'headphones', 'home', 'shirt', 'dress', 'footprints', 'watch'];

let error = null;
let values = {
  name: existing.name,
  slug: existing.slug,
  parent_id: existing.parent_id ? String(existing.parent_id) : '',
  icon: existing.icon || 'cpu',
  sort_order: String(existing.sort_order),
};

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action');

  if (action === 'delete') {
    const { subcategoryCount, productCount } = await getCategoryDeleteBlockers(id);
    if (subcategoryCount > 0) {
      error = `Can't delete — ${subcategoryCount} subcategor${subcategoryCount === 1 ? 'y' : 'ies'} still belong to this category. Move or delete those first.`;
    } else if (productCount > 0) {
      error = `Can't delete — ${productCount} product${productCount === 1 ? '' : 's'} still reference this category. Re-categorize or delete those first.`;
    } else {
      await deleteCategory(id);
      return Astro.redirect('/admin/categories');
    }
  } else {
    for (const key of Object.keys(values)) {
      values[key] = String(form.get(key) || '').trim();
    }
    const slug = values.slug || values.name.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    const isSubcategory = !!values.parent_id;

    if (!values.name) error = 'Name is required.';
    else if (Number(values.parent_id) === id) error = "A category can't be its own parent.";
    else if (await isCategorySlugTaken(slug, id)) error = `The slug "${slug}" is already used by another category.`;

    if (!error) {
      await updateCategory(id, {
        name: values.name,
        slug,
        parent_id: isSubcategory ? Number(values.parent_id) : null,
        icon: isSubcategory ? null : values.icon,
        sort_order: Number(values.sort_order) || 0,
      });
      return Astro.redirect('/admin/categories');
    }
    values.slug = slug;
  }
}
---

<AdminLayout title={`Edit — ${existing.name}`}>
  <a href="/admin/categories" class="text-sm text-ink-soft hover:text-brick mb-4 inline-block">← Back to categories</a>
  <h1 class="text-2xl font-display font-semibold mb-6">Edit category</h1>

  {error && (
    <div class="mb-5 rounded-lg bg-brick/10 border border-brick/30 text-brick text-sm px-4 py-2.5">{error}</div>
  )}

  <form
    method="POST"
    x-data={`{ parentId: '${values.parent_id}', icon: '${values.icon}' }`}
    class="flex flex-col gap-4 max-w-lg"
  >
    <div>
      <label class="text-xs font-semibold text-ink-soft">Name</label>
      <input name="name" required value={values.name} class="mt-1 w-full rounded-lg border border-line px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brick/40" />
    </div>
    <div>
      <label class="text-xs font-semibold text-ink-soft">URL slug</label>
      <input name="slug" value={values.slug} class="mt-1 w-full rounded-lg border border-line px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-brick/40" />
      <p class="text-xs text-ink-faint mt-1">Changing this changes every product URL under this category — links to the old URL will stop resolving.</p>
    </div>
    <div>
      <label class="text-xs font-semibold text-ink-soft">Parent category</label>
      <select name="parent_id" x-model="parentId" class="mt-1 w-full rounded-lg border border-line px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brick/40">
        <option value="">None — this is a top-level category</option>
        {topLevel.map((c) => (
          <option value={c.id} selected={String(c.id) === values.parent_id}>{c.name} (make this a subcategory of it)</option>
        ))}
      </select>
      <p class="text-xs text-ink-faint mt-1">Only two levels deep are supported — a subcategory can't itself have subcategories.</p>
    </div>

    <div x-show="!parentId" x-cloak>
      <label class="text-xs font-semibold text-ink-soft block mb-1.5">Icon (top-level categories only)</label>
      <div class="grid grid-cols-5 gap-2">
        {ICONS.map((name) => (
          <label class="flex flex-col items-center gap-1 cursor-pointer">
            <span
              class="flex items-center justify-center w-10 h-10 rounded-full border-2 transition-colors"
              :class={`icon === '${name}' ? 'border-brick bg-gold-soft text-gold-dark' : 'border-line text-ink-faint'`}
            >
              <Icon name={name} class="w-4.5 h-4.5" />
            </span>
            <input type="radio" name="icon" value={name} x-model="icon" class="sr-only" checked={name === values.icon} />
          </label>
        ))}
      </div>
    </div>

    <div>
      <label class="text-xs font-semibold text-ink-soft">Sort order (lower numbers show first)</label>
      <input name="sort_order" type="number" value={values.sort_order} class="mt-1 w-24 rounded-lg border border-line px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brick/40" />
    </div>

    <div class="flex gap-3 pt-2">
      <button type="submit" class="rounded-full bg-brick text-white font-semibold text-sm px-6 py-2.5 hover:bg-brick-dark transition-colors">Save changes</button>
      <a href="/admin/categories" class="rounded-full border border-line text-ink-soft text-sm px-6 py-2.5 hover:border-ink transition-colors">Cancel</a>
    </div>
  </form>

  <form method="POST" class="mt-10 pt-6 border-t border-line" onsubmit="return confirm('Delete this category? This only works if nothing references it.')">
    <input type="hidden" name="action" value="delete" />
    <button type="submit" class="text-sm text-red-700 hover:underline">Delete this category</button>
  </form>
</AdminLayout>
