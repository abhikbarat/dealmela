---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getMostClickedForAdmin, getRecentSearchesForAdmin } from '../../lib/queries.js';
import { formatRelativeTime } from '../../lib/format.js';

const days = Number(Astro.url.searchParams.get('days')) === 30 ? 30 : 7;
const mostClicked = await getMostClickedForAdmin({ days, limit: 15 });
const searches = await getRecentSearchesForAdmin({ limit: 40 });
const zeroResultSearches = searches.filter((s) => s.results_count === 0);
---

<AdminLayout title="Analytics">
  <h1 class="text-2xl font-display font-semibold mb-6">Analytics</h1>

  <section class="mb-10">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-bold text-ink-soft uppercase tracking-wide">Most-clicked deals</h2>
      <div class="flex gap-2 text-xs">
        <a href="/admin/analytics?days=7" class:list={['px-2.5 py-1 rounded-full border', days === 7 ? 'bg-ink text-white border-ink' : 'border-line text-ink-soft']}>7 days</a>
        <a href="/admin/analytics?days=30" class:list={['px-2.5 py-1 rounded-full border', days === 30 ? 'bg-ink text-white border-ink' : 'border-line text-ink-soft']}>30 days</a>
      </div>
    </div>
    {mostClicked.length === 0 ? (
      <p class="text-sm text-ink-faint py-6">No clicks logged in this window yet.</p>
    ) : (
      <div class="rounded-xl border border-line bg-white overflow-hidden">
        {mostClicked.map((p, i) => (
          <a href={`/admin/products/${p.id}/edit`} class="flex items-center justify-between px-4 py-2.5 text-sm border-t border-line first:border-t-0 hover:bg-paper-warm">
            <span class="flex items-center gap-2.5 min-w-0">
              <span class="text-ink-faint w-5 shrink-0 text-xs">{i + 1}</span>
              <span class="line-clamp-1">{p.name}</span>
            </span>
            <span class="font-semibold tabular-nums shrink-0 ml-3">{p.clicks} click{p.clicks === 1 ? '' : 's'}</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <section>
    <h2 class="text-sm font-bold text-ink-soft uppercase tracking-wide mb-3">Recent searches</h2>
    {zeroResultSearches.length > 0 && (
      <p class="text-xs text-ink-faint mb-3">{zeroResultSearches.length} of the last {searches.length} searches found nothing — a good source of ideas for what to add next.</p>
    )}
    {searches.length === 0 ? (
      <p class="text-sm text-ink-faint py-6">No searches logged yet.</p>
    ) : (
      <div class="rounded-xl border border-line bg-white overflow-hidden">
        {searches.map((s) => (
          <div class="flex items-center justify-between px-4 py-2 text-sm border-t border-line first:border-t-0">
            <span class="line-clamp-1">"{s.query}"</span>
            <span class:list={['text-xs shrink-0 ml-3', s.results_count === 0 ? 'text-brick font-semibold' : 'text-ink-faint']}>
              {s.results_count === 0 ? 'No results' : `${s.results_count} result${s.results_count === 1 ? '' : 's'}`} · {formatRelativeTime(s.searched_at)}
            </span>
          </div>
        ))}
      </div>
    )}
  </section>
</AdminLayout>
