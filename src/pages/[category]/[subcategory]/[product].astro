---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ImageGallery from '../../../components/ImageGallery.astro';
import PriceBlock from '../../../components/PriceBlock.astro';
import PlatformBadge from '../../../components/PlatformBadge.astro';
import CTAButton from '../../../components/CTAButton.astro';
import StickyCTA from '../../../components/StickyCTA.astro';
import ProductRail from '../../../components/ProductRail.astro';
import { getProductBySlug, getRelatedProducts } from '../../../lib/queries.js';
import { formatRelativeTime, platformDisplay } from '../../../lib/format.js';
import { buildProductSchema } from '../../../lib/schema.js';

const { category: categorySlug, subcategory: subcategorySlug, product: productSlug } = Astro.params;
const product = await getProductBySlug(productSlug);

if (!product) {
  return Astro.rewrite('/404');
}

// Canonicalize: if someone lands on a stale category/subcategory pairing
// (e.g. after the Admin re-categorizes a product), send them to the correct URL
// rather than silently rendering it under the wrong breadcrumb.
if (product.category_slug !== categorySlug || product.subcategory_slug !== subcategorySlug) {
  return Astro.redirect(`/${product.category_slug}/${product.subcategory_slug}/${product.slug}`, 301);
}

const images = Array.isArray(product.images) ? product.images : JSON.parse(product.images);
const specs = Array.isArray(product.specs) ? product.specs : JSON.parse(product.specs || '[]');
const related = await getRelatedProducts({
  productId: product.id,
  categoryId: product.category_id,
  subcategoryId: product.subcategory_id,
  limit: 8,
});

const canonicalUrl = new URL(Astro.url.pathname, Astro.site || Astro.url.origin).toString();
const jsonLd = buildProductSchema(product, canonicalUrl);
const platform = platformDisplay(product);
---

<BaseLayout
  title={product.name}
  description={product.editorial_note}
  jsonLd={jsonLd}
  ogImage={images[0]}
>
  <article class="mx-auto max-w-6xl px-4 sm:px-6 pt-5 sm:pt-8 pb-24 sm:pb-16">
    <nav class="text-xs text-ink-faint mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:text-brick">Home</a> <span class="mx-1">/</span>
      <a href={`/${product.category_slug}`} class="hover:text-brick">{product.category_name}</a> <span class="mx-1">/</span>
      <a href={`/${product.category_slug}/${product.subcategory_slug}`} class="hover:text-brick">{product.subcategory_name}</a>
    </nav>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
      <ImageGallery images={images} productName={product.name} />

      <div class="flex flex-col gap-5">
        <div>
          {product.brand && <p class="text-xs font-semibold text-gold-dark uppercase tracking-wide mb-1">{product.brand}</p>}
          <h1 class="font-display text-2xl sm:text-3xl font-semibold text-ink leading-tight">{product.name}</h1>
          <div class="flex items-center gap-2.5 mt-3">
            <PlatformBadge product={product} />
            {product.is_featured && (
              <span class="inline-flex items-center rounded-full bg-gold text-white text-[10px] font-bold tracking-wide uppercase px-2 py-0.5">
                Editor&rsquo;s Pick
              </span>
            )}
          </div>
        </div>

        <PriceBlock current={product.current_price} original={product.original_price} size="detail" />

        {product.source_rating && product.source_review_count && (
          <div class="flex items-center gap-1.5 text-sm text-ink-soft">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-gold"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
            <span class="font-semibold text-ink">{Number(product.source_rating).toFixed(1)}★</span>
            <span>· {product.source_review_count.toLocaleString('en-IN')}+ ratings on {platform.label}{product.rating_checked_at ? `, as of ${new Date(product.rating_checked_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}` : ''}</span>
          </div>
        )}

        <p class="text-xs text-ink-faint -mt-2">Price last verified {formatRelativeTime(product.price_last_verified)}</p>

        <div id="primary-cta-anchor">
          <CTAButton product={product} sourcePage="product_detail" size="large" />
        </div>

        <div class="pt-2 border-t border-line">
          <h2 class="font-display text-base font-semibold text-ink mt-4 mb-2">Why we picked this ↓</h2>
          <p class="text-sm text-ink-soft leading-relaxed">{product.editorial_note}</p>
        </div>

        {specs.length > 0 && (
          <div class="pt-2 border-t border-line">
            <h2 class="font-display text-base font-semibold text-ink mt-4 mb-2.5">Key details</h2>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
              {specs.map((s: { label: string; value: string }) => (
                <div class="flex justify-between sm:block gap-3 py-1 border-b border-line/60 sm:border-none">
                  <dt class="text-ink-faint shrink-0">{s.label}</dt>
                  <dd class="text-ink font-medium text-right sm:text-left">{s.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}
      </div>
    </div>

    {related.length > 0 && (
      <section class="mt-16">
        <h2 class="font-display text-xl sm:text-2xl font-semibold text-ink mb-4">Related Deals</h2>
        <ProductRail products={related} />
      </section>
    )}
  </article>

  <StickyCTA product={product} />
</BaseLayout>
