---
import Icon from './Icon.astro';

interface Props {
  categories: Record<string, any>[];
}
const { categories } = Astro.props;
---

<div class="scroll-rail -mx-4 sm:mx-0 px-4 sm:px-0 flex gap-3 overflow-x-auto snap-x snap-mandatory">
  {categories.map((cat) => (
    <a
      href={`/${cat.slug}`}
      class="snap-start shrink-0 flex flex-col items-center gap-2 rounded-2xl border border-line bg-white/60 px-5 py-4 w-28 hover:border-gold hover:-translate-y-0.5 transition-all"
    >
      <span class="flex items-center justify-center w-10 h-10 rounded-full bg-gold-soft text-gold-dark">
        <Icon name={cat.icon} class="w-5 h-5" />
      </span>
      <span class="text-xs font-semibold text-ink text-center leading-tight">{cat.name}</span>
    </a>
  ))}
</div>
