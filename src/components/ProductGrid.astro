---
interface Props {
  products: Record<string, any>[];
  id?: string;
}
const { products, id } = Astro.props;
import ProductCard from './ProductCard.astro';
---

<div id={id} class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3.5 sm:gap-5">
  {products.map((product) => (
    <ProductCard product={product} />
  ))}
</div>
