---
import { platformDisplay } from '../lib/format.js';

const { product } = Astro.props;
const platform = platformDisplay(product);

const styles = {
  amazon: 'bg-[#232f3e] text-white',
  flipkart: 'bg-[#2874f0] text-white',
  other: 'bg-ink text-paper',
};
---

<span class:list={['inline-flex items-center rounded-md text-[11px] font-semibold px-2 py-1 tracking-wide', styles[platform.key]]}>
  {platform.label}
</span>
