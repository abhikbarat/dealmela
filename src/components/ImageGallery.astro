---
interface Props {
  images: string[];
  productName: string;
}
const { images, productName } = Astro.props;
---

<div
  x-data={`{
    active: 0,
    total: ${images.length},
    touchX: 0,
    next() { this.active = (this.active + 1) % this.total },
    prev() { this.active = (this.active - 1 + this.total) % this.total },
    onTouchStart(e) { this.touchX = e.changedTouches[0].clientX },
    onTouchEnd(e) {
      const dx = e.changedTouches[0].clientX - this.touchX;
      if (dx < -40) this.next();
      if (dx > 40) this.prev();
    }
  }`}
  class="flex flex-col gap-3"
>
  <div
    class="relative aspect-square rounded-2xl overflow-hidden bg-paper-warm border border-line"
    @touchstart="onTouchStart($event)"
    @touchend="onTouchEnd($event)"
  >
    {images.map((src, i) => (
      <img
        src={src}
        alt={`${productName} — image ${i + 1} of ${images.length}`}
        loading={i === 0 ? 'eager' : 'lazy'}
        decoding="async"
        width="900"
        height="900"
        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-200"
        x-show={`active === ${i}`}
        x-cloak
      />
    ))}

    <button
      @click="prev()"
      aria-label="Previous image"
      class="absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/90 flex items-center justify-center shadow-sm hover:bg-white transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" class="w-4 h-4"><path d="M15 6l-6 6 6 6" /></svg>
    </button>
    <button
      @click="next()"
      aria-label="Next image"
      class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/90 flex items-center justify-center shadow-sm hover:bg-white transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" class="w-4 h-4"><path d="M9 6l6 6-6 6" /></svg>
    </button>

    <div class="absolute bottom-2.5 left-1/2 -translate-x-1/2 flex gap-1.5">
      {images.map((_, i) => (
        <span
          class="w-1.5 h-1.5 rounded-full transition-all"
          :class={`active === ${i} ? 'bg-white w-4' : 'bg-white/50'`}
        ></span>
      ))}
    </div>
  </div>

  <div class="grid grid-cols-3 gap-2.5">
    {images.map((src, i) => (
      <button
        @click={`active = ${i}`}
        class="aspect-square rounded-lg overflow-hidden border-2 transition-colors"
        :class={`active === ${i} ? 'border-brick' : 'border-transparent'`}
      >
        <img src={src} alt="" loading="lazy" decoding="async" width="200" height="200" class="w-full h-full object-cover" />
      </button>
    ))}
  </div>
</div>
